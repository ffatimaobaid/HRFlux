# Minimal .gitignore for private team repository
# Only excludes files that are genuinely unnecessary for team collaboration

# Python cache files (regenerated automatically)
__pycache__/
*.py[cod]
*$py.class

# Virtual environments (team members create their own)
venv/
env/
.venv/

# IDE specific files (personal preferences)
.vscode/
.idea/
*.swp
*.swo

# OS specific files
.DS_Store
Thumbs.db

# Large temporary files (can be regenerated)
*.tmp
*.temp

# HRFlux Custom Ignores - SECURITY SENSITIVE
backend/config.py
backend/queries.db
*.db
*.sqlite3
backend/venv/
node_modules/
.env
.next/
dist/
build/
*.mp3
*.mp4
*.bak
